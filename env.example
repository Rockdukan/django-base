DEBUG=true
TEMPLATE_DEBUG=true

# В production обязательно замените.
SECRET_KEY=django-insecure-change-me

# Через запятую.
ALLOWED_HOSTS=127.0.0.1,localhost

# Через запятую. В dev можно оставить как есть.
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8050,http://localhost:8050

# Пример: sqlite:////abs/path/db.sqlite3 или postgres://user:pass@host:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# Поддерживаемые схемы в каркасе: locmemcache://, filecache:///tmp/django-cache, dbcache://django_cache
CACHE_URL=locmemcache://

# SMTP (production.py использует эти переменные)
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=webmaster@localhost

